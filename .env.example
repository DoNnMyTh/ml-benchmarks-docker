# Copy to .env and fill in. .env is gitignored.

# HuggingFace token (needed for ImageNet-1k download via HF, and optional model caching)
# Get at https://huggingface.co/settings/tokens
HF_TOKEN=

# Docker Hub (already logged in via `docker login`, but set here if scripts need it)
DOCKER_USER=donnmyth
DOCKER_REPO=ml-benchmarks

# Default GPU count (auto-detected if unset)
NUM_GPUS=

# Default mode: quick | full
BENCH_MODE=quick
